# -----------------------------------------------------------------------------
# Environment Variables Reference
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` for local development and fill in real values.
# NEVER commit an actual `.env` / `.env.local` file with real secrets.
# -----------------------------------------------------------------------------

# --- App -------------------------------------------------------------------
# Public base URL of the site (used for absolute links, metadata, callbacks).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Database (Phase: Prisma / PostgreSQL) ----------------------------------
# Connection string for the primary database. Added once Prisma + Docker land.
DATABASE_URL=""

# --- Authentication ----------------------------------------------------------
# Secret used to sign/encrypt auth session tokens. Added with the auth phase.
AUTH_SECRET=""

# --- Auto Trader Connect API (future integration phase) --------------------
# Credentials for Auto Trader's Connect APIs (Stock Sync, Search, Valuations).
AUTOTRADER_API_KEY=""
AUTOTRADER_API_SECRET=""
AUTOTRADER_ADVERTISER_ID=""
# Shared secret used to verify incoming Auto Trader webhook signatures.
AUTOTRADER_WEBHOOK_SECRET=""

# --- Email -------------------------------------------------------------------
# Identifier for the transactional email provider (e.g. "resend", "postmark").
EMAIL_PROVIDER=""
