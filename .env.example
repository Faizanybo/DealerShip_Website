# -----------------------------------------------------------------------------
# Environment Variables Reference
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` for local development and fill in real values.
# NEVER commit an actual `.env` / `.env.local` file with real secrets.
# -----------------------------------------------------------------------------

# --- App -------------------------------------------------------------------
# Public base URL of the site (used for absolute links, metadata, callbacks).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- PostgreSQL (local development, via Docker Compose) --------------------
# These are consumed by `docker-compose.yml` (via `--env-file .env.local`) to
# provision the local Postgres container, and are also the values that make up
# DATABASE_URL below. Change them here AND keep DATABASE_URL in sync — they
# describe the same database. These development-only defaults are safe to
# keep as-is locally; they are never used in production.
POSTGRES_DB="autotrader_dev"
POSTGRES_USER="autotrader"
POSTGRES_PASSWORD="autotrader_dev_password"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"

# --- Database (Prisma) -------------------------------------------------------
# Prisma's connection string. Must correspond to the POSTGRES_* values above:
# postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@<POSTGRES_HOST>:<POSTGRES_PORT>/<POSTGRES_DB>?schema=public
# NOTE: intentionally NOT prefixed with NEXT_PUBLIC_ — this must never reach the browser.
DATABASE_URL="postgresql://autotrader:autotrader_dev_password@localhost:5432/autotrader_dev?schema=public"

# --- Authentication ----------------------------------------------------------
# Secret used to sign/encrypt auth session tokens. Added with the auth phase.
AUTH_SECRET=""

# --- Auto Trader Connect API (future integration phase) --------------------
# Credentials for Auto Trader's Connect APIs (Stock Sync, Search, Valuations).
AUTOTRADER_API_KEY=""
AUTOTRADER_API_SECRET=""
AUTOTRADER_ADVERTISER_ID=""
# Shared secret used to verify incoming Auto Trader webhook signatures.
AUTOTRADER_WEBHOOK_SECRET=""

# --- Email -------------------------------------------------------------------
# Identifier for the transactional email provider (e.g. "resend", "postmark").
EMAIL_PROVIDER=""
